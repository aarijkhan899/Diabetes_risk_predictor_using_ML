<!-- ============================================================
     Diabetes Risk Predictor - Results Page
     ============================================================ -->

<%
  prediction   = @result["prediction"].to_i
  label        = @result["label"]
  confidence   = @result["confidence"].to_f
  probabilities = @result["probabilities"] || {}
  shap_values  = @result["shap_values"]   || {}
  guidance     = @result["guidance"]
  model_used   = @result["model_used"]
  disclaimer   = @result["disclaimer"]

  is_diabetic  = prediction == 1
  badge_bg     = is_diabetic ? "bg-danger"  : "bg-success"
  card_border  = is_diabetic ? "border-danger" : "border-success"
  card_header  = is_diabetic ? "bg-danger text-white" : "bg-success text-white"
  icon         = is_diabetic ? "bi-exclamation-triangle-fill" : "bi-shield-check-fill"

  bar_class = confidence_bar_class(confidence)
%>

<div class="row justify-content-center">
  <div class="col-lg-10 col-xl-9">

    <!-- Back button -->
    <div class="mb-3">
      <%= link_to root_path, class: "btn btn-outline-secondary btn-sm" do %>
        <i class="bi bi-arrow-left me-1"></i>Make Another Prediction
      <% end %>
    </div>

    <!-- -- RESULT CARD --------------------------------------- -->
    <div class="card mb-4 border-2 <%= card_border %>">
      <div class="card-header <%= card_header %> py-3">
        <div class="d-flex align-items-center gap-3">
          <i class="bi <%= icon %> fs-3"></i>
          <div>
            <h4 class="mb-0 fw-bold">Prediction Result</h4>
            <small class="opacity-75">Based on the submitted clinical measurements</small>
          </div>
          <div class="ms-auto">
            <span class="badge <%= badge_bg %> fs-5 px-3 py-2 rounded-pill">
              <%= label %>
            </span>
          </div>
        </div>
      </div>

      <div class="card-body p-4">
        <div class="row g-4">

          <!-- Confidence -->
          <div class="col-md-6">
            <h6 class="text-muted text-uppercase fw-semibold mb-2 small">Model Confidence</h6>
            <div class="d-flex align-items-baseline gap-2 mb-2">
              <span class="display-5 fw-bold"><%= number_with_precision(confidence, precision: 1) %>%</span>
              <span class="text-muted">confident</span>
            </div>
            <div class="progress" style="height: 12px; border-radius: 6px;">
              <div
                class="progress-bar <%= bar_class %>"
                role="progressbar"
                style="width: <%= confidence %>%"
                aria-valuenow="<%= confidence %>"
                aria-valuemin="0"
                aria-valuemax="100"
              ></div>
            </div>
          </div>

          <!-- Probability Breakdown -->
          <div class="col-md-6">
            <h6 class="text-muted text-uppercase fw-semibold mb-2 small">Probability Breakdown</h6>
            <div class="d-flex flex-column gap-2">
              <div class="d-flex justify-content-between align-items-center">
                <span class="small fw-semibold text-success">
                  <i class="bi bi-shield-check me-1"></i>Non-Diabetic
                </span>
                <div class="d-flex align-items-center gap-2" style="width: 65%;">
                  <div class="progress flex-grow-1" style="height: 10px; border-radius: 5px;">
                    <div
                      class="progress-bar bg-success"
                      style="width: <%= probabilities['non_diabetic'] %>%"
                    ></div>
                  </div>
                  <span class="small fw-bold text-success" style="min-width: 45px; text-align:right;">
                    <%= number_with_precision(probabilities['non_diabetic'], precision: 1) %>%
                  </span>
                </div>
              </div>
              <div class="d-flex justify-content-between align-items-center">
                <span class="small fw-semibold text-danger">
                  <i class="bi bi-exclamation-triangle me-1"></i>Diabetic
                </span>
                <div class="d-flex align-items-center gap-2" style="width: 65%;">
                  <div class="progress flex-grow-1" style="height: 10px; border-radius: 5px;">
                    <div
                      class="progress-bar bg-danger"
                      style="width: <%= probabilities['diabetic'] %>%"
                    ></div>
                  </div>
                  <span class="small fw-bold text-danger" style="min-width: 45px; text-align:right;">
                    <%= number_with_precision(probabilities['diabetic'], precision: 1) %>%
                  </span>
                </div>
              </div>
            </div>
          </div>

        </div><!-- /.row -->
      </div><!-- /.card-body -->
    </div><!-- /.result card -->

    <!-- -- GUIDANCE BOX -------------------------------------- -->
    <% if is_diabetic %>
      <div class="alert alert-danger d-flex gap-3 mb-4" role="alert">
        <div class="fs-3"><i class="bi bi-heart-pulse-fill"></i></div>
        <div>
          <strong>Clinical Guidance</strong><br />
          <%= guidance %>
        </div>
      </div>
    <% else %>
      <div class="alert alert-success d-flex gap-3 mb-4" role="alert">
        <div class="fs-3"><i class="bi bi-check-circle-fill"></i></div>
        <div>
          <strong>Clinical Guidance</strong><br />
          <%= guidance %>
        </div>
      </div>
    <% end %>

    <div class="row g-4 mb-4">

      <!-- -- SHAP CHART ---------------------------------------- -->
      <% if shap_values.any? %>
        <div class="col-lg-7">
          <div class="card h-100">
            <div class="card-header bg-light">
              <h6 class="mb-0 fw-bold">
                <i class="bi bi-bar-chart-horizontal-fill text-primary me-2"></i>
                Feature Importance (SHAP Values)
              </h6>
            </div>
            <div class="card-body">
              <p class="text-muted small mb-3">
                SHAP values show each feature's contribution to the prediction.
                Positive values push toward <em>Diabetic</em>;
                negative values push toward <em>Non-Diabetic</em>.
              </p>
              <canvas id="shapChart" style="max-height: 320px;"></canvas>
            </div>
          </div>
        </div>
      <% end %>

      <!-- -- INPUT SUMMARY ------------------------------------ -->
      <div class="col-lg-<%= shap_values.any? ? '5' : '12' %>">
        <div class="card h-100">
          <div class="card-header bg-light">
            <h6 class="mb-0 fw-bold">
              <i class="bi bi-table text-secondary me-2"></i>
              Submitted Values
            </h6>
          </div>
          <div class="card-body p-0">
            <table class="table table-sm table-striped mb-0">
              <thead class="table-dark">
                <tr>
                  <th>Feature</th>
                  <th class="text-end">Value</th>
                </tr>
              </thead>
              <tbody>
                <% @feature_labels.each do |key, label_text| %>
                  <tr>
                    <td class="text-muted small"><%= label_text %></td>
                    <td class="text-end fw-semibold">
                      <%= number_with_precision(@input_params[key].to_f,
                            precision: key == "DiabetesPedigreeFunction" ? 3 : 1,
                            strip_insignificant_zeros: true) %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div><!-- /.row -->

    <!-- -- MODEL INFORMATION ----------------------------------- -->
    <div class="card mb-4">
      <div class="card-header bg-light">
        <h6 class="mb-0 fw-bold">
          <i class="bi bi-cpu-fill text-info me-2"></i>Model Information
        </h6>
      </div>
      <div class="card-body">
        <div class="row g-3 text-center">
          <div class="col-sm-4">
            <div class="p-3 rounded bg-light">
              <div class="text-muted small mb-1">Algorithm</div>
              <div class="fw-bold"><%= model_used %></div>
            </div>
          </div>
          <div class="col-sm-4">
            <div class="p-3 rounded bg-light">
              <div class="text-muted small mb-1">Model AUC-ROC</div>
              <div class="fw-bold">
                <%= @result["auc"] ? number_with_precision(@result["auc"].to_f, precision: 4) : "N/A" %>
              </div>
            </div>
          </div>
          <div class="col-sm-4">
            <div class="p-3 rounded bg-light">
              <div class="text-muted small mb-1">Training Dataset</div>
              <div class="fw-bold">Pima Indians (768 records)</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- -- DISCLAIMER BOX --------------------------------------- -->
    <div class="alert alert-warning d-flex gap-3 mb-4" role="alert">
      <div class="fs-4 pt-1"><i class="bi bi-shield-exclamation"></i></div>
      <div>
        <strong>Important Disclaimer</strong><br />
        <% if disclaimer.present? %>
          <%= disclaimer %>
        <% else %>
          This tool is a decision-support aid only. It is not a diagnostic instrument.
          Clinician oversight is mandatory before any patient-facing action.
          Model trained on Pima Indian female population only.
        <% end %>
      </div>
    </div>

    <!-- Back button (bottom) -->
    <div class="text-center mb-2">
      <%= link_to root_path, class: "btn btn-primary btn-lg px-5" do %>
        <i class="bi bi-arrow-left-circle me-2"></i>Make Another Prediction
      <% end %>
    </div>

  </div><!-- /.col -->
</div><!-- /.row -->

<!-- -- SHAP Chart JS -------------------------------------------- -->
<% if shap_values.any? %>
  <script>
    (function () {
      var shapData  = <%= shap_values.to_json.html_safe %>;
      var labels    = Object.keys(shapData);
      var values    = labels.map(function (k) { return shapData[k]; });

      // Sort by absolute value descending
      var combined = labels.map(function (l, i) { return { label: l, value: values[i] }; });
      combined.sort(function (a, b) { return Math.abs(b.value) - Math.abs(a.value); });

      var sortedLabels = combined.map(function (d) { return d.label; });
      var sortedValues = combined.map(function (d) { return d.value; });

      var colors = sortedValues.map(function (v) {
        return v >= 0
          ? "rgba(220, 53, 69, 0.75)"   // red  -> pushes toward Diabetic
          : "rgba(25, 135, 84, 0.75)";  // green -> pushes toward Non-Diabetic
      });
      var borderColors = sortedValues.map(function (v) {
        return v >= 0 ? "rgba(220, 53, 69, 1)" : "rgba(25, 135, 84, 1)";
      });

      var ctx = document.getElementById("shapChart").getContext("2d");
      new Chart(ctx, {
        type: "bar",
        data: {
          labels: sortedLabels,
          datasets: [{
            label: "SHAP Value",
            data:  sortedValues,
            backgroundColor: colors,
            borderColor: borderColors,
            borderWidth: 1,
            borderRadius: 4
          }]
        },
        options: {
          indexAxis: "y",
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function (ctx) {
                  var v = ctx.parsed.x.toFixed(4);
                  var dir = ctx.parsed.x >= 0 ? "^ Diabetic" : "v Non-Diabetic";
                  return " " + v + "  (" + dir + ")";
                }
              }
            }
          },
          scales: {
            x: {
              grid: { color: "rgba(0,0,0,0.06)" },
              ticks: { font: { size: 11 } }
            },
            y: {
              ticks: { font: { size: 12 } }
            }
          }
        }
      });
    })();
  </script>
<% end %>
