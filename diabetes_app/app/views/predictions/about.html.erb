<!-- ============================================================
     Diabetes Risk Predictor — About Page
     ============================================================ -->

<div class="row justify-content-center">
  <div class="col-lg-9">

    <h1 class="display-6 fw-bold text-dark mb-1">
      <i class="bi bi-info-circle-fill text-primary me-2"></i>About DiabetesRisk AI
    </h1>
    <p class="lead text-muted mb-4">
      A dissertation research project exploring machine learning for diabetes risk prediction.
    </p>

    <!-- Project Overview -->
    <div class="card mb-4">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-book-fill me-2"></i>Project Overview</h5>
      </div>
      <div class="card-body">
        <p>
          This system demonstrates a full-stack clinical decision-support prototype built as part
          of a dissertation research project. It combines machine learning (Python), a REST API
          (Flask), and a web interface (Ruby on Rails) to provide diabetes risk assessments
          using the well-known <strong>Pima Indians Diabetes Dataset</strong>.
        </p>
        <p class="mb-0">
          The system trains five classifier algorithms, selects the best by AUC-ROC, and exposes
          predictions and SHAP-based explanations through a REST API consumed by this web
          application.
        </p>
      </div>
    </div>

    <!-- Model Information Card -->
    <% if @model_info.any? %>
      <div class="card mb-4">
        <div class="card-header bg-info text-white">
          <h5 class="mb-0"><i class="bi bi-cpu-fill me-2"></i>Live Model Statistics</h5>
        </div>
        <div class="card-body">
          <div class="row g-3 text-center">
            <div class="col-6 col-md-3">
              <div class="p-3 rounded bg-light">
                <div class="text-muted small mb-1">Algorithm</div>
                <div class="fw-bold"><%= @model_info["model_name"] || "N/A" %></div>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="p-3 rounded bg-light">
                <div class="text-muted small mb-1">AUC-ROC</div>
                <div class="fw-bold text-primary">
                  <%= @model_info["auc"] ? number_with_precision(@model_info["auc"].to_f, precision: 4) : "N/A" %>
                </div>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="p-3 rounded bg-light">
                <div class="text-muted small mb-1">F1 Score</div>
                <div class="fw-bold text-success">
                  <%= @model_info["f1"] ? number_with_precision(@model_info["f1"].to_f, precision: 4) : "N/A" %>
                </div>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="p-3 rounded bg-light">
                <div class="text-muted small mb-1">Recall</div>
                <div class="fw-bold text-warning">
                  <%= @model_info["recall"] ? number_with_precision(@model_info["recall"].to_f, precision: 4) : "N/A" %>
                </div>
              </div>
            </div>
          </div>

          <% if @model_info["features"].present? %>
            <div class="mt-3">
              <strong>Input Features:</strong>
              <span class="text-muted"><%= @model_info["features"].join(", ") %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="alert alert-secondary">
        <i class="bi bi-wifi-off me-2"></i>
        Live model statistics unavailable — Flask API may not be running.
        Start it with: <code>cd ml &amp;&amp; python api.py</code>
      </div>
    <% end %>

    <!-- ML Pipeline -->
    <div class="card mb-4">
      <div class="card-header bg-secondary text-white">
        <h5 class="mb-0"><i class="bi bi-diagram-3-fill me-2"></i>ML Pipeline</h5>
      </div>
      <div class="card-body">
        <ol class="mb-0">
          <li class="mb-2">
            <strong>Data Loading</strong> — Pima Indians Diabetes Dataset (768 records, 8 features)
            loaded via <code>ucimlrepo</code> with CSV fallback.
          </li>
          <li class="mb-2">
            <strong>Preprocessing</strong> — Biologically invalid zeros replaced with column medians;
            features standardised with <code>StandardScaler</code>.
          </li>
          <li class="mb-2">
            <strong>Class Balancing</strong> — SMOTE oversampling applied to address the
            ~65/35 class imbalance.
          </li>
          <li class="mb-2">
            <strong>Model Selection</strong> — Five algorithms evaluated with 5-fold stratified
            cross-validation and grid-search hyperparameter tuning:
            Logistic Regression, Random Forest, XGBoost, LightGBM, SVM.
          </li>
          <li class="mb-2">
            <strong>Explainability</strong> — SHAP values computed per prediction using
            <code>TreeExplainer</code> (tree models) or <code>KernelExplainer</code> (others).
          </li>
          <li>
            <strong>Success Thresholds</strong> — AUC-ROC &ge; 0.85, F1 &ge; 0.80,
            Recall &ge; 0.78 (from dissertation proposal).
          </li>
        </ol>
      </div>
    </div>

    <!-- Dataset Info -->
    <div class="card mb-4">
      <div class="card-header bg-light">
        <h5 class="mb-0"><i class="bi bi-database-fill me-2"></i>Dataset</h5>
      </div>
      <div class="card-body">
        <table class="table table-sm table-bordered mb-0">
          <tbody>
            <tr><th style="width:35%">Name</th><td>Pima Indians Diabetes Dataset</td></tr>
            <tr><th>Source</th><td>UCI Machine Learning Repository (ID: 34)</td></tr>
            <tr><th>Records</th><td>768</td></tr>
            <tr><th>Features</th><td>8 clinical measurements</td></tr>
            <tr><th>Target</th><td>Outcome (0 = Non-Diabetic, 1 = Diabetic)</td></tr>
            <tr>
              <th>Population</th>
              <td>Adult females of Pima Indian heritage, aged &ge; 21 years</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="alert alert-warning d-flex gap-3" role="alert">
      <div class="fs-4"><i class="bi bi-shield-exclamation"></i></div>
      <div>
        <strong>Research Use Only</strong><br />
        This system has not been clinically validated and must not be used to make medical
        decisions. It is intended solely as a proof-of-concept for dissertation research.
        The model was trained exclusively on Pima Indian female data; its applicability to
        other populations is unknown.
      </div>
    </div>

    <div class="text-center mt-2">
      <%= link_to root_path, class: "btn btn-primary px-4" do %>
        <i class="bi bi-clipboard2-pulse me-2"></i>Try the Predictor
      <% end %>
    </div>

  </div>
</div>
