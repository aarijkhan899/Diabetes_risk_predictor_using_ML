<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="DiabetesRisk AI - Clinical decision-support tool for diabetes risk prediction." />
    <title>DiabetesRisk AI</title>

    <!-- Bootstrap 5.3 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous"
    />

    <!-- Bootstrap Icons -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
      rel="stylesheet"
    />

    <!-- Chart.js -->
    <script
      src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"
      crossorigin="anonymous"
    ></script>

    <style>
      :root {
        --brand-primary:   #1a6fc4;
        --brand-secondary: #0d4f8b;
        --brand-danger:    #dc3545;
        --brand-success:   #198754;
      }

      body {
        background-color: #f8f9fa;
        font-family: "Segoe UI", system-ui, -apple-system, sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* -- Navbar -------------------------------------------- */
      .navbar-brand {
        font-weight: 700;
        font-size: 1.4rem;
        letter-spacing: -0.5px;
      }

      .navbar-brand .brand-icon {
        color: #74c0fc;
        margin-right: 6px;
      }

      /* -- Cards --------------------------------------------- */
      .card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
      }

      .card-header {
        border-radius: 12px 12px 0 0 !important;
        font-weight: 600;
      }

      /* -- Risk badge ---------------------------------------- */
      .badge-danger  { background-color: var(--brand-danger)  !important; }
      .badge-success { background-color: var(--brand-success) !important; }

      /* -- Footer -------------------------------------------- */
      footer {
        margin-top: auto;
        background-color: #212529;
        color: #adb5bd;
        font-size: 0.82rem;
      }

      footer a { color: #74c0fc; text-decoration: none; }
      footer a:hover { text-decoration: underline; }

      /* -- Flash messages ------------------------------------ */
      .flash-container {
        position: sticky;
        top: 56px;
        z-index: 1030;
      }

      /* -- Form styling -------------------------------------- */
      .form-label {
        font-weight: 500;
        font-size: 0.9rem;
      }

      .input-group-text {
        font-size: 0.85rem;
      }

      /* -- Tooltip cursor ------------------------------------ */
      [data-bs-toggle="tooltip"] { cursor: help; }
    </style>
  </head>

  <body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <a class="navbar-brand" href="<%= root_path %>">
          <i class="bi bi-heart-pulse-fill brand-icon"></i>DiabetesRisk AI
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarMain"
          aria-controls="navbarMain"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
          <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link <%= 'active' if request.path == root_path %>" href="<%= root_path %>">
                <i class="bi bi-clipboard2-pulse me-1"></i>Predict
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= 'active' if request.path == about_path %>" href="<%= about_path %>">
                <i class="bi bi-info-circle me-1"></i>About
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="<%= health_path %>" target="_blank">
                <i class="bi bi-activity me-1"></i>API Health
              </a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <div class="flash-container">
      <% if flash[:notice].present? %>
        <div class="alert alert-success alert-dismissible fade show mb-0 rounded-0" role="alert">
          <div class="container">
            <i class="bi bi-check-circle-fill me-2"></i><%= flash[:notice] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        </div>
      <% end %>
      <% if flash[:alert].present? %>
        <div class="alert alert-danger alert-dismissible fade show mb-0 rounded-0" role="alert">
          <div class="container">
            <i class="bi bi-exclamation-triangle-fill me-2"></i><%= flash[:alert] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        </div>
      <% end %>
      <% if flash[:warning].present? %>
        <div class="alert alert-warning alert-dismissible fade show mb-0 rounded-0" role="alert">
          <div class="container">
            <i class="bi bi-exclamation-circle-fill me-2"></i><%= flash[:warning] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Main Content -->
    <main class="flex-grow-1 py-4">
      <div class="container">
        <%= yield %>
      </div>
    </main>

    <!-- Footer -->
    <footer class="py-4">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-md-6 mb-2 mb-md-0">
            <strong class="text-white">
              <i class="bi bi-heart-pulse-fill text-info me-1"></i>DiabetesRisk AI
            </strong>
            <span class="ms-2">- Dissertation Research Project</span>
          </div>
          <div class="col-md-6 text-md-end">
            <i class="bi bi-shield-exclamation text-warning me-1"></i>
            <strong class="text-warning">Clinical Disclaimer:</strong>
            This tool is for research purposes only and is not a medical diagnostic instrument.
            Always consult a qualified clinician.
          </div>
        </div>
        <hr class="border-secondary my-2" />
        <div class="row">
          <div class="col-12 text-center">
            Model trained on Pima Indians Diabetes Dataset (UCI ML Repository, id=34).
            Population: adult females of Pima Indian heritage aged &ge; 21.
            Results must not be generalised beyond this cohort without further validation.
          </div>
        </div>
      </div>
    </footer>

    <!-- Bootstrap 5 JS Bundle -->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
      crossorigin="anonymous"
    ></script>

    <!-- Initialise Bootstrap tooltips globally -->
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        var tooltipTriggerList = [].slice.call(
          document.querySelectorAll('[data-bs-toggle="tooltip"]')
        );
        tooltipTriggerList.forEach(function (el) {
          new bootstrap.Tooltip(el, { placement: "top", trigger: "hover focus" });
        });
      });
    </script>
  </body>
</html>
